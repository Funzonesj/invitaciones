{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "controlhorario.funzonepro.com" }],
      "destination": "/fichaje.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }]
    },
    {
      "source": "/(.*).html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }]
    }
  ]
}
